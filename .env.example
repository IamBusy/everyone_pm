# EveryonePM environment configuration
#
# Option A – Global config (works in every directory, recommended):
#   mkdir -p ~/.eopm
#   cp .env.example ~/.eopm/.env
#   # then edit ~/.eopm/.env
#
# Option B – Local config (this project directory only):
#   cp .env.example .env
#
# Priority (highest → lowest): real env vars > local .env > ~/.eopm/.env

# --- Anthropic (when EOPM_MODEL starts with "anthropic/") ---
# Required for Anthropic models (used by LiteLLM)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# --- OpenAI-compatible gateway (when EOPM_MODEL starts with "openai/") ---
# For gateways that implement /v1/chat/completions
# NOTE: your gateway may require a base URL that includes a path prefix.
# Example:
#   https://genai-sg-og.tiktok-row.org/gpt/openapi/online/v2/crawl
OPENAI_API_KEY=YOUR_GATEWAY_KEY
OPENAI_API_BASE=https://YOUR_GATEWAY_HOST/PATH_PREFIX

# Optional: add default headers for gateway auth/tracing.
# Example:
# EOPM_DEFAULT_HEADERS={"X-TT-LOGID":"${your_logid}"}
# EOPM_DEFAULT_HEADERS={"X-TT-LOGID":"abc123"}

# --- Azure OpenAI (when EOPM_MODEL starts with "azure/") ---
# Standard Azure OpenAI env vars (works with azure.openai.azure.com style endpoints)
AZURE_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_API_BASE=https://YOUR_RESOURCE_NAME.openai.azure.com
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=YOUR_AZURE_DEPLOYMENT

# For environments where you use the AzureOpenAI client against a custom gateway,
# you may need to provide an explicit azure_endpoint (see your reference code).
# NOTE: this may also include a required path prefix.
# AZURE_ENDPOINT=https://genai-sg-og.tiktok-row.org/gpt/openapi/online/v2/crawl

# --- Model selection ---
# LiteLLM model string.
# Anthropic example (recommended default): anthropic/claude-3-5-sonnet-latest
# OpenAI gateway example: openai/gpt-5.2-2025-12-11
# Azure example: azure/gpt-4o-mini
EOPM_MODEL=anthropic/claude-3-5-sonnet-latest

# Optional: Max tokens for each assistant response
# (If unset, EveryonePM defaults internally.)
# For reasoning models (o1, gpt-5, etc.), set to 40000:
# EOPM_MAX_TOKENS=40000
